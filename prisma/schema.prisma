generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "linux-musl-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Core Models ─────────────────────────────────────────────────────────────

model Place {
  id        String   @id @default(cuid())
  name      String
  latitude  Float
  longitude Float
  timezone  String   @default("America/Panama")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  spaces       Space[]
  reservations Reservation[]

  @@map("places")
}

model Space {
  id          String  @id @default(cuid())
  placeId     String  @map("place_id")
  name        String
  reference   String?
  capacity    Int
  description String?
  opensAt     String  @map("opens_at") // HH:mm
  closesAt    String  @map("closes_at") // HH:mm
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  place        Place   @relation(fields: [placeId], references: [id], onDelete: Cascade)
  reservations Reservation[]

  deviceDesired DeviceDesired?
  deviceReported DeviceReported?
  telemetryAggregations TelemetryAggregation[]
  alerts Alert[]

  @@map("spaces")
}

// placeId is denormalized here for query performance (filter reservations by place without JOIN)
// Trade-off: slight redundancy accepted; a space does not change its place after creation
model Reservation {
  id              String   @id @default(cuid())
  spaceId         String   @map("space_id")
  placeId         String   @map("place_id") // denormalized
  clientName      String   @map("client_name")
  clientEmail     String   @map("client_email")
  reservationDate DateTime @map("reservation_date") // ISO date (date only, no time)
  startTime       String   @map("start_time") // HH:mm
  endTime         String   @map("end_time")   // HH:mm
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  space Space @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  // placeId is denormalized — no FK constraint enforced at DB level to keep it flexible
  place Place @relation(fields: [placeId], references: [id], onDelete: Cascade)

  @@index([spaceId, reservationDate])
  @@index([placeId, reservationDate])
  @@index([clientEmail, reservationDate])
  @@map("reservations")
}

// ─── IoT / Digital Twin Models ───────────────────────────────────────────────

// Desired state published by the cloud to the device
model DeviceDesired {
  id                  String   @id @default(cuid())
  spaceId             String   @unique @map("space_id")
  samplingIntervalSec Int      @default(10) @map("sampling_interval_sec")
  co2AlertThreshold   Int      @default(1000) @map("co2_alert_threshold")
  updatedAt           DateTime @updatedAt @map("updated_at")

  space Space @relation(fields: [spaceId], references: [id], onDelete: Cascade)

  @@map("device_desired")
}

// Actual state reported by the device (reflects its current running config)
model DeviceReported {
  id                  String    @id @default(cuid())
  spaceId             String    @unique @map("space_id")
  samplingIntervalSec Int?      @map("sampling_interval_sec")
  co2AlertThreshold   Int?      @map("co2_alert_threshold")
  firmwareVersion     String?   @map("firmware_version")
  reportedAt          DateTime? @map("reported_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  space Space @relation(fields: [spaceId], references: [id], onDelete: Cascade)

  @@map("device_reported")
}

// Aggregated telemetry windows (empirical data, NOT part of digital twin)
model TelemetryAggregation {
  id             String   @id @default(cuid())
  spaceId        String   @map("space_id")
  windowStart    DateTime @map("window_start")
  windowEnd      DateTime @map("window_end")
  avgTempC       Float?   @map("avg_temp_c")
  avgHumidityPct Float?   @map("avg_humidity_pct")
  avgCo2Ppm      Float?   @map("avg_co2_ppm")
  maxCo2Ppm      Float?   @map("max_co2_ppm")
  avgOccupancy   Float?   @map("avg_occupancy")
  maxOccupancy   Int?     @map("max_occupancy")
  avgPowerW      Float?   @map("avg_power_w")
  sampleCount    Int      @default(0) @map("sample_count")

  space Space @relation(fields: [spaceId], references: [id], onDelete: Cascade)

  @@index([spaceId, windowStart])
  @@map("telemetry_aggregations")
}

// Alerts generated by the alert engine based on telemetry rules
model Alert {
  id         String     @id @default(cuid())
  spaceId    String     @map("space_id")
  kind       AlertKind
  startedAt  DateTime   @map("started_at")
  resolvedAt DateTime?  @map("resolved_at")
  metaJson   Json       @map("meta_json")
  createdAt  DateTime   @default(now()) @map("created_at")

  space Space @relation(fields: [spaceId], references: [id], onDelete: Cascade)

  @@index([spaceId, kind])
  @@index([spaceId, startedAt])
  @@map("alerts")
}

enum AlertKind {
  CO2
  OCCUPANCY_MAX
  OCCUPANCY_UNEXPECTED
}
